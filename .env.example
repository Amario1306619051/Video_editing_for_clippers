# Copy to .env. Optional runtime config — read from the project-root .env by
# transcriber.py (Whisper) and the CLIPPER_* env vars below.

# ===== Whisper STT =====
# Model: tiny|base|small|medium|large-v3. Empty = auto (medium on GPU, base on CPU).
# medium needs a GPU (torch build matching the CUDA driver) — see CLAUDE.md "Whisper / GPU".
# WHISPER_MODEL=medium
# Language: code like "id". Empty = auto-detect. Indonesian content → set "id".
WHISPER_LANGUAGE=id

# ===== Vision model — AI auto-box (prompt → bounding box) =====
# Leave empty to disable the auto-box feature (manual boxing still works).
# OpenAI-compatible vision endpoint (Qwen-VL); returns bbox_2d in 0-1000 coords.
VISION_BASE_URL=https://internal-rnd.balitower.co.id/models/qwen36-img
VISION_MODEL=qwen36-35b-a3b-nvfp4
# VISION_API_KEY=dummy

# ===== Text model — thumbnail headline ideas =====
# OpenAI-compatible text endpoint (Qwen3). Leave empty to disable the
# "Generate ideas" button on the Thumbnail step (typing your own still works).
VLLM_BASE_URL=https://internal-rnd.balitower.co.id/models/qwen35
VLLM_MODEL=gb10-qwen35-122b-nvfp4-4node-100k
VLLM_API_KEY=dummy

# ===== Speaker diarization — optional, for the shot-director's "who is box1" =====
# pyannote.audio (Phase 3). Empty HF_TOKEN = diarization off (the director still
# decides box1 visually). Setup: pip install 'pyannote.audio>=4' torchcodec, accept
# the gated models at hf.co/pyannote/speaker-diarization-3.1 AND
# hf.co/pyannote/segmentation-3.0, then create a READ token at hf.co/settings/tokens.
HF_TOKEN=
# DIARIZE_ENABLED=true
# DIARIZE_MODEL=pyannote/speaker-diarization-3.1

# ===== Pexels — stock images for the illustration cutaways =====
# Free key at https://www.pexels.com/api/ . Empty = the Illustration search is off.
PEXELS_API_KEY=
# CLIPPER_CANDIDATES=12   # how many candidate images per search

# ===== Encoder / download (optional) =====
# CLIPPER_ENCODER=libx264
# CLIPPER_COOKIES_BROWSER=firefox
