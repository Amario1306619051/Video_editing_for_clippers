# Copy to .env. Optional runtime config — read from the project-root .env by
# transcriber.py (Whisper) and the CLIPPER_* env vars below.

# ===== Whisper STT =====
# Model: tiny|base|small|medium|large-v3. Kosong = auto (medium di GPU, base di CPU).
# medium butuh GPU (torch build cocok CUDA driver) — lihat CLAUDE.md "Whisper / GPU".
# WHISPER_MODEL=medium
# Bahasa: kode spt "id". Kosong = auto-detect. Konten Indonesia → set "id".
WHISPER_LANGUAGE=id

# ===== Encoder / download (opsional) =====
# CLIPPER_ENCODER=libx264
# CLIPPER_COOKIES_BROWSER=firefox
